# Neptune / Gremlin
GREMLIN_ENDPOINT=wss://REDACTED_NEPTUNE_HOST:8182/gremlin

# ElastiCache (Valkey)
REDIS_HOST=REDACTED_VALKEY_HOST
REDIS_PORT=6379

# AgentCore Runtime
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:ap-northeast-2:REDACTED_ACCOUNT_ID:runtime/REDACTED_TRAVEL_AGENT_ID

# AWS
AWS_REGION=ap-northeast-2
BEDROCK_REGION=us-east-1

# DynamoDB
DYNAMODB_TABLE_NAME=ota-planned-products

# AgentCore Gateway (MCP)
GATEWAY_MCP_URL=https://REDACTED_GATEWAY_HOST/mcp

# Lambda deployment
LAMBDA_ROLE_ARN=arn:aws:iam::REDACTED_ACCOUNT_ID:role/ota-travel-tools-lambda-role
GATEWAY_ROLE_ARN=arn:aws:iam::REDACTED_ACCOUNT_ID:role/Agent-core-Gateway
